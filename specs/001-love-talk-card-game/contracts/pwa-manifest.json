  "screenshots": [],

  "_vite_plugin_pwa_config": {
    "_comment": "以下為 vite.config.ts 中 VitePWA() 的對應設定（供開發參考，非 manifest 標準欄位）",
    "registerType": "autoUpdate",
    "includeAssets": ["fonts/**", "icons/**", "sounds/**"],
    "workbox": {
      "globPatterns": ["**/*.{js,css,html,json,woff2,png,svg,ogg,mp3}"],
      "runtimeCaching": [],
      "_note": "所有資產均為靜態，使用 precache 策略，無需 runtimeCaching"
    },
    "devOptions": {
      "enabled": true,
      "type": "module"
    }
  }
}
